# Copy to .env and fill in as needed: cp .env.example .env
# These configure the AI review classifier only. The deterministic analytics
# dashboard runs without any of them.

# Provider API key. Required only to (re)generate review classifications via
# `python -m ai.classify`. The dashboard reads the cache and never calls the model.
OPENAI_API_KEY=

# Optional. An OpenAI-compatible endpoint such as OpenRouter
# (https://openrouter.ai/api/v1) or a local Ollama server. Leave blank for OpenAI.
OPENAI_BASE_URL=

# Model used for classification, and part of the cache key the dashboard reads,
# so it must match the model the cache was built with. OpenRouter expects a
# prefixed id, e.g. openai/gpt-4o-mini.
AI_MODEL=gpt-4o-mini

# Prompt version. Bumping it forces a clean reclassification.
AI_PROMPT_VERSION=v1

# Optional. Override the sidecar cache location (used mainly in tests).
# CLASSIFICATION_CACHE_DB=data/classification_cache.db
